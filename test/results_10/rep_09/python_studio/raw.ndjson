{"type":"assistant","message":{"id":"chatcmpl-c9dJsLvJaI2VDgp8q9UStPHSXMyHBvLh","type":"message","role":"assistant","content":[{"type":"tool_use","id":"xQeHuJbYdUQCzYH39F8GWhWkUH3B9iO3","name":"Write","input":{"file_path":"/Volumes/Studio Storage/kDrive/documenti/dev/ai/ccllrun/test/results_10/rep_09/python_studio/solution.py","content":"def merge_intervals(intervals):\n    \"\"\"Merge overlapping or adjacent intervals.\n\n    Normalises reversed pairs, merges overlaps/adjacency, returns\n    a sorted list of unique tuples. Input is never mutated.\n    \"\"\"\n    if not intervals:\n        return []\n\n    # Normalise: ensure (low, high) for every pair\n    normalised = sorted((min(a, b), max(a, b)) for a, b in intervals)\n\n    merged = [normalised[0]]\n    for start, end in normalised[1:]:\n        prev_start, prev_end = merged[-1]\n        # Overlap or adjacency → extend\n        if start <= prev_end + 1:\n            merged[-1] = (prev_start, max(prev_end, end))\n        else:\n            merged.append((start, end))\n\n    return merged\n"}}],"model":"gemma-big","stop_reason":null,"stop_sequence":null,"usage":{"cache_read_input_tokens":0,"input_tokens":18224,"output_tokens":0},"context_management":null},"parent_tool_use_id":null,"session_id":"e6a02a62-a1b2-4f81-a10d-94bbaa107f92","uuid":"b1f8ba3e-b4dd-49f3-8dd4-5c618f770efc"}
