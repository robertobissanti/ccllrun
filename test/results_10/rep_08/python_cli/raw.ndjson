{"type":"assistant","message":{"id":"chatcmpl-vP0wmyzlyMmsv8PxHYfwgrihsOKcxclX","type":"message","role":"assistant","content":[{"type":"tool_use","id":"v4fpWFyUTbDQ4kFfKxT4mxwMnoL1pQa8","name":"Write","input":{"file_path":"/Volumes/Studio Storage/kDrive/documenti/dev/ai/ccllrun/test/results_10/rep_08/python_cli/solution.py","content":"def merge_intervals(intervals):\n    \"\"\"Merge overlapping or adjacent intervals.\n\n    Normalises reversed pairs, merges overlaps/adjacency, returns\n    a sorted list of unique tuples. Uses only the standard library.\n    \"\"\"\n    # Normalise: ensure (low, high) for every pair\n    normalised = [tuple(sorted(iv)) for iv in intervals]\n\n    # Deduplicate while preserving order\n    seen = set()\n    unique = []\n    for iv in normalised:\n        if iv not in seen:\n            seen.add(iv)\n            unique.append(iv)\n\n    # Sort by start, then by end\n    unique.sort()\n\n    merged = []\n    for start, end in unique:\n        if merged and start <= merged[-1][1] + 1:\n            # Overlapping or adjacent\n            merged[-1] = (merged[-1][0], max(merged[-1][1], end))\n        else:\n            merged.append((start, end))\n\n    return [tuple(iv) for iv in merged]\n"}}],"model":"gemma-big","stop_reason":null,"stop_sequence":null,"usage":{"cache_read_input_tokens":0,"input_tokens":18090,"output_tokens":0},"context_management":null},"parent_tool_use_id":null,"session_id":"798e8d7e-ab49-40f4-a466-458df91630af","uuid":"ab9b2628-f0ef-4531-ba44-9c96453d0273"}
