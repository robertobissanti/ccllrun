#!/usr/bin/env bash
# ccllrun — run Claude Code on local llama-server instances through an Anthropic-to-OpenAI proxy.
#
# Configuration precedence, from weakest to strongest:
#   1. built-in defaults
#   2. JSON config (~/.ccllrun/config.json, or --config <file>)
#   3. ccllrun_* environment variables
#   4. CLI flags (see --help-ccllrun)
#
# Unknown arguments are passed through to `claude`.

set -u

CC_DIR="$HOME/.ccllrun"
VENV="$CC_DIR/venv"
CONFIG_FILE="$CC_DIR/config.json"

# ---------- defaults ----------
PORT=8765
BACKEND="llama.cpp"
LLAMA_BIN="llama-server"
MLX_BIN="mlx_lm.server"
BIG_PORT=8001
SMALL_PORT=8002
EMBED_PORT=8003
BIG_GGUF="$HOME/.lmstudio/models/unsloth/Qwen3.6-35B-A3B-GGUF/Qwen3.6-35B-A3B-UD-Q4_K_XL.gguf"
SMALL_GGUF="$HOME/.lmstudio/models/ghost-actual/Qwen3.6-9B-Heretic-History-Q4_K_M-GGUF/history-9b-Q4_K_M.gguf"
EMBED_GGUF=""           # Empty disables embeddings; an embedding GGUF enables /v1/embeddings.
MODEL_EMBED="embed"     # Public alias for the embedding model.
KB_DIR=""               # Optional global knowledge-base directory passed to Claude Code with --add-dir.
EMBED_BATCH=8192        # Physical embedding batch size; must cover the longest indexed chunks.
BIG_MLX=""
SMALL_MLX=""
MODEL_BIG="qwen-big"
MODEL_SMALL="small-fast"
PDF_MODE="hybrid"
CTX_BIG=98304
CTX_SMALL=32768
BATCH=2048
BATCH_SMALL=""          # Empty uses BATCH; lower values reduce memory pressure for the small model.
UBATCH=""               # Prefill micro-batch (-ub); empty uses BATCH. Smaller values reduce peak memory.
UBATCH_SMALL=""         # Empty uses the small batch size, not the big UBATCH, because -ub must be <= -b.
CACHE_REUSE=256         # Minimum gap for KV cache reuse around changed blocks (--cache-reuse).
CACHE_REUSE_SMALL=""    # Empty uses CACHE_REUSE.
KV_TYPE="q8_0"          # f16 maximizes quality; q8_0 reduces memory use.
NGL=99
PARALLEL=1
PARALLEL_SMALL=""       # Empty uses PARALLEL; fewer slots give each small-model request more context.
REASONING_BUDGET=4096
PRESENCE_PENALTY=1.5
MMPROJ=""               # Empty auto-detects mmproj-*.gguf next to BIG_GGUF.
NO_SMALL=0
EXTRA_BIG_FLAGS=""      # Extra flags passed as-is to the big llama-server.
# Maximum Claude Code output. Keep this below CTX_BIG to leave room for prompt
# context and avoid Metal OOMs in llama-server.
CC_MAX_OUTPUT_TOKENS=32000
# Absolute auto-compact threshold. Claude Code hardcodes 200k for non-Anthropic
# models and ignores CLAUDE_CODE_MAX_CONTEXT_TOKENS; the effective control is
# CLAUDE_CODE_AUTO_COMPACT_WINDOW. Keep it under CTX_BIG with output headroom so
# compaction happens before llama-server reaches its context/OOM boundary.
CC_AUTO_COMPACT_WINDOW=115000
# Tool search (ENABLE_TOOL_SEARCH) sends only a few tools up front and loads the
# rest on demand. It can reduce prefill cost with many MCP servers, but it is a
# startup option and depends on proxy support for tool references. Default off.
CC_TOOL_SEARCH=0

# ---------- JSON config helpers ----------
json_get() {  # json_get <file> <key>
  python3 - "$1" "$2" <<'PY' 2>/dev/null
import json, sys, os
try:
    v = json.load(open(sys.argv[1])).get(sys.argv[2])
    if isinstance(v, str):
        v = os.path.expanduser(v)
    if v is not None:
        print(v if not isinstance(v, bool) else int(v))
except Exception:
    pass
PY
}

# ---------- environment overrides ----------
apply_env() {
  PORT="${ccllrun_PROXY_PORT:-$PORT}"
  BACKEND="${ccllrun_BACKEND:-$BACKEND}"
  LLAMA_BIN="${ccllrun_LLAMA_BIN:-$LLAMA_BIN}"
  MLX_BIN="${ccllrun_MLX_BIN:-$MLX_BIN}"
  BIG_PORT="${ccllrun_BIG_PORT:-$BIG_PORT}"
  SMALL_PORT="${ccllrun_SMALL_PORT:-$SMALL_PORT}"
  BIG_GGUF="${ccllrun_GGUF_BIG:-$BIG_GGUF}"
  SMALL_GGUF="${ccllrun_GGUF_SMALL:-$SMALL_GGUF}"
  BIG_MLX="${ccllrun_MLX_BIG:-$BIG_MLX}"
  SMALL_MLX="${ccllrun_MLX_SMALL:-$SMALL_MLX}"
  MODEL_BIG="${ccllrun_MODEL_BIG:-$MODEL_BIG}"
  MODEL_SMALL="${ccllrun_MODEL_SMALL:-$MODEL_SMALL}"
  PDF_MODE="${ccllrun_PDF_MODE:-$PDF_MODE}"
  CTX_BIG="${ccllrun_CTX_BIG:-$CTX_BIG}"
  KV_TYPE="${ccllrun_KV_TYPE:-$KV_TYPE}"
  MMPROJ="${ccllrun_MMPROJ:-$MMPROJ}"
}

apply_config() {  # apply_config <file>
  local f="$1" v
  [[ -f "$f" ]] || return 0
  for pair in \
    "PORT proxy_port" "BACKEND backend" "LLAMA_BIN llama_bin" "MLX_BIN mlx_bin" "BIG_PORT big_port" \
    "SMALL_PORT small_port" "EMBED_PORT embed_port" "BIG_GGUF big_gguf" "SMALL_GGUF small_gguf" \
    "EMBED_GGUF embed_gguf" "MODEL_EMBED model_embed" "EMBED_BATCH embed_batch" "KB_DIR kb_dir" "BIG_MLX big_mlx" "SMALL_MLX small_mlx" \
    "MODEL_BIG model_big" "MODEL_SMALL model_small" "PDF_MODE pdf_mode" \
    "CTX_BIG ctx_big" "CTX_SMALL ctx_small" "BATCH batch" "BATCH_SMALL batch_small" \
    "UBATCH ubatch" "UBATCH_SMALL ubatch_small" "CACHE_REUSE cache_reuse" "CACHE_REUSE_SMALL cache_reuse_small" \
    "KV_TYPE kv_type" \
    "NGL ngl" "PARALLEL parallel" "PARALLEL_SMALL parallel_small" "REASONING_BUDGET reasoning_budget" \
    "PRESENCE_PENALTY presence_penalty" "MMPROJ mmproj" "NO_SMALL no_small" \
    "EXTRA_BIG_FLAGS extra_big_flags" "CC_MAX_OUTPUT_TOKENS cc_max_output_tokens" \
    "CC_AUTO_COMPACT_WINDOW cc_auto_compact_window" "CC_TOOL_SEARCH cc_tool_search"
  do
    set -- $pair
    v="$(json_get "$f" "$2")"
    [[ -n "$v" ]] && printf -v "$1" '%s' "$v"
  done
}

set_cli_override() {  # set_cli_override <VAR> <VALUE>
  printf -v "$1" '%s' "$2"
}

usage_ccllrun() {
  cat <<EOF
ccllrun [opzioni ccllrun] [argomenti claude...]

Opzioni:
  --config <file>        usa un config JSON alternativo
  --backend <name>       llama.cpp | mlx-lm (default $BACKEND)
  --big-gguf <path>      modello grande
  --small-gguf <path>    modello piccolo ("" per disattivarlo)
  --big-mlx <dir>        cartella MLX grande (backend mlx-lm)
  --small-mlx <dir>      cartella MLX piccola (backend mlx-lm)
  --no-small             non avviare il modello piccolo
  --ctx <n>              context del big (default $CTX_BIG)
  --batch-small <n>      batch del small (default: stesso del big, $BATCH)
  --ubatch <n>           micro-batch di prefill -ub del big (default: = batch)
  --ubatch-small <n>     micro-batch di prefill del small (default: = batch del small; deve essere <= batch)
  --cache-reuse <n>      gap minimo riuso KV cache, big (default $CACHE_REUSE)
  --cache-reuse-small <n> idem per il small (default: stesso del big)
  --kv <tipo>            f16|q8_0|q4_0 per la KV cache (default $KV_TYPE)
  --mmproj <path|off>    projector visione (default: autodetect)
  --parallel <n>         slot paralleli llama-server big (default $PARALLEL)
  --parallel-small <n>   slot paralleli del small (default: stesso del big, $PARALLEL)
  --pdf-mode <m>         text|image|hybrid (default $PDF_MODE)
  --port <n>             porta proxy (default $PORT)
  --tool-search          attiva la tool search di Claude Code (prefill piu' veloce
                         con molti server MCP; opzione d'avvio)
  --no-tool-search       disattiva la tool search (scavalca settings.json globale)
  stop                   ferma i llama-server
  logs [big|small|proxy] segui il log indicato (tail -f, default: big)
  --help-ccllrun         questo aiuto

Config JSON ($CONFIG_FILE), chiavi: backend, big_gguf, small_gguf, big_mlx, small_mlx, ctx_big, ctx_small,
batch, batch_small, ubatch, ubatch_small, cache_reuse, cache_reuse_small, kv_type, ngl, parallel, parallel_small, reasoning_budget, presence_penalty, mmproj,
pdf_mode, proxy_port, big_port, small_port, embed_port, embed_gguf, model_embed, kb_dir, model_big, model_small,
no_small, extra_big_flags, llama_bin, mlx_bin, cc_auto_compact_window,
cc_max_output_tokens, cc_tool_search.
EOF
}

# ---------- argument parsing: consume ccllrun flags, pass everything else to claude ----------
CLAUDE_ARGS=()
CLI_OVERRIDES=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --config)        CONFIG_FILE="$2"; shift 2 ;;
    --backend)       CLI_OVERRIDES+=("BACKEND=$2"); shift 2 ;;
    --big-gguf)      CLI_OVERRIDES+=("BIG_GGUF=$2"); shift 2 ;;
    --small-gguf)    CLI_OVERRIDES+=("SMALL_GGUF=$2"); shift 2 ;;
    --big-mlx)       CLI_OVERRIDES+=("BIG_MLX=$2"); shift 2 ;;
    --small-mlx)     CLI_OVERRIDES+=("SMALL_MLX=$2"); shift 2 ;;
    --no-small)      CLI_OVERRIDES+=("NO_SMALL=1"); shift ;;
    --ctx)           CLI_OVERRIDES+=("CTX_BIG=$2"); shift 2 ;;
    --batch-small)   CLI_OVERRIDES+=("BATCH_SMALL=$2"); shift 2 ;;
    --ubatch)        CLI_OVERRIDES+=("UBATCH=$2"); shift 2 ;;
    --ubatch-small)  CLI_OVERRIDES+=("UBATCH_SMALL=$2"); shift 2 ;;
    --cache-reuse)   CLI_OVERRIDES+=("CACHE_REUSE=$2"); shift 2 ;;
    --cache-reuse-small) CLI_OVERRIDES+=("CACHE_REUSE_SMALL=$2"); shift 2 ;;
    --kv)            CLI_OVERRIDES+=("KV_TYPE=$2"); shift 2 ;;
    --mmproj)        CLI_OVERRIDES+=("MMPROJ=$2"); shift 2 ;;
    --parallel)      CLI_OVERRIDES+=("PARALLEL=$2"); shift 2 ;;
    --parallel-small) CLI_OVERRIDES+=("PARALLEL_SMALL=$2"); shift 2 ;;
    --pdf-mode)      CLI_OVERRIDES+=("PDF_MODE=$2"); shift 2 ;;
    --port)          CLI_OVERRIDES+=("PORT=$2"); shift 2 ;;
    --tool-search)   CLI_OVERRIDES+=("CC_TOOL_SEARCH=1"); shift ;;
    --no-tool-search) CLI_OVERRIDES+=("CC_TOOL_SEARCH=0"); shift ;;
    --help-ccllrun)  usage_ccllrun; exit 0 ;;
    *)               CLAUDE_ARGS+=("$1"); shift ;;
  esac
done

# ---------- logs do not need config, so handle them before startup ----------
if [[ "${CLAUDE_ARGS[0]:-}" == "logs" ]]; then
  case "${CLAUDE_ARGS[1]:-big}" in
    big)   exec tail -f "$CC_DIR/llama-big.log" ;;
    small) exec tail -f "$CC_DIR/llama-small.log" ;;
    proxy) exec tail -f "$CC_DIR/proxy.log" ;;
    *) echo "uso: ccllrun logs [big|small|proxy]" >&2; exit 1 ;;
  esac
fi

apply_config "$CONFIG_FILE"
apply_env
for ov in ${CLI_OVERRIDES[@]+"${CLI_OVERRIDES[@]}"}; do
  set_cli_override "${ov%%=*}" "${ov#*=}"
done

# ---------- pass-through commands / stop ----------
case "${CLAUDE_ARGS[0]:-}" in
  --version|-v|--help|-h|doctor|mcp|config|update|install|migrate-installer|setup-token)
    exec claude "${CLAUDE_ARGS[@]}" ;;
  stop)
    for f in "$CC_DIR"/llama-*.pid "$CC_DIR"/proxy.pid; do
      [[ -f "$f" ]] && kill "$(cat "$f")" 2>/dev/null
      rm -f "$f"
    done
    for p in "$BIG_PORT" "$SMALL_PORT" "$EMBED_PORT" "$PORT"; do
      for pid in $(/usr/sbin/lsof -ti "tcp:$p" -sTCP:LISTEN 2>/dev/null); do
        kill "$pid" 2>/dev/null
      done
    done
    echo "[ccllrun] server fermati."
    exit 0 ;;
esac

# "servers" starts big+small+proxy in the background and exits; Studio uses this.
SERVERS_ONLY=0
[[ "${CLAUDE_ARGS[0]:-}" == "servers" ]] && SERVERS_ONLY=1

if ! grep -q 'CLAUDE_CODE_ATTRIBUTION_HEADER' "$HOME/.claude/settings.json" 2>/dev/null; then
  echo "[ccllrun] ATTENZIONE: aggiungi \"CLAUDE_CODE_ATTRIBUTION_HEADER\": \"0\" in env di ~/.claude/settings.json" >&2
fi

http_code() {  # http_code <url>
  curl -s -o /dev/null -w '%{http_code}' "$1" 2>/dev/null
}
health() { http_code "http://127.0.0.1:$1/health"; }
openai_health() { http_code "http://127.0.0.1:$1/v1/models"; }
proxy_health() { http_code "http://127.0.0.1:$PORT/v1/models"; }
model_health() {  # model_health <port>
  if [[ "$BACKEND" == "mlx-lm" ]]; then
    openai_health "$1"
  else
    health "$1"
  fi
}
wait_health() {  # wait_health <port> [attempts]
  local port="$1" attempts="${2:-600}"
  for _ in $(seq 1 "$attempts"); do
    [[ "$(health "$port")" == "200" ]] && return 0
    sleep 1
  done
  return 1
}
wait_openai_health() {  # wait_openai_health <port> [attempts]
  local port="$1" attempts="${2:-600}"
  for _ in $(seq 1 "$attempts"); do
    [[ "$(openai_health "$port")" == "200" ]] && return 0
    sleep 1
  done
  return 1
}
verify_stack_ready() {
  [[ "$(model_health "$BIG_PORT")" == "200" ]] || return 1
  [[ -z "$SMALL_UPSTREAM" || "$(model_health "$SMALL_PORT")" == "200" ]] || return 1
  [[ -z "$EMBED_UPSTREAM" || "$(health "$EMBED_PORT")" == "200" ]] || return 1
  [[ "$(proxy_health)" == "200" ]] || return 1
}
configure_upstreams() {
  SMALL_UPSTREAM=""
  if [[ "$BACKEND" == "mlx-lm" ]]; then
    [[ "$NO_SMALL" != "1" && -n "$SMALL_MLX" && "$SMALL_MLX" != "$BIG_MLX" ]] && SMALL_UPSTREAM="http://127.0.0.1:$SMALL_PORT"
  else
    [[ "$NO_SMALL" != "1" && -n "$SMALL_GGUF" && "$SMALL_GGUF" != "$BIG_GGUF" ]] && SMALL_UPSTREAM="http://127.0.0.1:$SMALL_PORT"
  fi

  EMBED_UPSTREAM=""
  [[ "$BACKEND" != "mlx-lm" && -n "$EMBED_GGUF" ]] && EMBED_UPSTREAM="http://127.0.0.1:$EMBED_PORT"
}
stack_has_residue() {
  local f p pid cmd
  for f in "$CC_DIR"/llama-*.pid "$CC_DIR"/proxy.pid; do
    [[ -f "$f" ]] && return 0
  done
  for p in "$BIG_PORT" "$SMALL_PORT" "$EMBED_PORT" "$PORT"; do
    [[ -n "$(/usr/sbin/lsof -ti "tcp:$p" -sTCP:LISTEN 2>/dev/null)" ]] && return 0
  done
  while read -r pid cmd; do
    [[ -n "$pid" && "$pid" != "$$" && "$pid" != "$PPID" ]] || continue
    case "$cmd" in
      *"ccllrun servers"*|*"$CC_DIR/proxy.py"*) return 0 ;;
    esac
  done < <(ps -axo pid=,command=)
  return 1
}
cleanup_stack() {
  local f p pid
  for f in "$CC_DIR"/llama-*.pid "$CC_DIR"/proxy.pid; do
    [[ -f "$f" ]] && kill "$(cat "$f")" 2>/dev/null
    rm -f "$f"
  done
  while read -r pid cmd; do
    [[ -n "$pid" && "$pid" != "$$" && "$pid" != "$PPID" ]] || continue
    case "$cmd" in
      *"ccllrun servers"*|*"$CC_DIR/proxy.py"*) kill "$pid" 2>/dev/null ;;
    esac
  done < <(ps -axo pid=,command=)
  for p in "$BIG_PORT" "$SMALL_PORT" "$EMBED_PORT" "$PORT"; do
    for pid in $(/usr/sbin/lsof -ti "tcp:$p" -sTCP:LISTEN 2>/dev/null); do
      kill "$pid" 2>/dev/null
    done
  done
  sleep 1
  while read -r pid cmd; do
    [[ -n "$pid" && "$pid" != "$$" && "$pid" != "$PPID" ]] || continue
    case "$cmd" in
      *"ccllrun servers"*|*"$CC_DIR/proxy.py"*) kill -9 "$pid" 2>/dev/null ;;
    esac
  done < <(ps -axo pid=,command=)
  for p in "$BIG_PORT" "$SMALL_PORT" "$EMBED_PORT" "$PORT"; do
    for pid in $(/usr/sbin/lsof -ti "tcp:$p" -sTCP:LISTEN 2>/dev/null); do
      kill -9 "$pid" 2>/dev/null
    done
  done
}
mkdir -p "$CC_DIR"
mlx_dir_error() {
  python3 - "$1" <<'PY'
import json, sys
from pathlib import Path

p = Path(sys.argv[1]).expanduser()
if not p.is_dir():
    print("cartella non trovata")
    raise SystemExit
if not (p / "config.json").is_file():
    print("config.json non trovato")
    raise SystemExit
parts = sorted(x.name for x in p.glob("*.part"))
if parts:
    print("download incompleto: " + ", ".join(parts[:3]))
    raise SystemExit
index = p / "model.safetensors.index.json"
if index.is_file():
    try:
        data = json.loads(index.read_text())
        expected = sorted(set((data.get("weight_map") or {}).values()))
    except Exception as exc:
        print(f"model.safetensors.index.json non leggibile: {exc}")
        raise SystemExit
    missing = [name for name in expected if not (p / name).is_file()]
    if missing:
        print("file safetensors mancanti: " + ", ".join(missing[:3]))
        raise SystemExit
elif not any(p.glob("*.safetensors")):
    print("nessun file .safetensors trovato")
PY
}

# Print a reason when a GGUF is an embedding model. Embedding models cannot serve
# chat reliably as big/small because they do not generate normal stop behavior.
# Empty output means "looks generative". The strongest signal is the
# "<arch>.pooling_type" GGUF key; the model name is only a fallback.
gguf_is_embedding() {  # gguf_is_embedding <path> -> prints reason, or empty for generative models
  python3 - "$1" <<'PY' 2>/dev/null
import struct, sys
from pathlib import Path
p = Path(sys.argv[1]).expanduser()
if not p.is_file():
    raise SystemExit  # gestito altrove (GGUF non trovato)
try:
    with open(p, "rb") as f:
        if f.read(4) != b"GGUF":
            raise SystemExit
        struct.unpack("<I", f.read(4))  # version
        f.read(8)                       # tensor count
        n_kv, = struct.unpack("<Q", f.read(8))
        def rd_str():
            n, = struct.unpack("<Q", f.read(8)); return f.read(n).decode("utf-8", "replace")
        def rd_val(t):
            if t == 0:  return struct.unpack("<B", f.read(1))[0]
            if t == 1:  return struct.unpack("<b", f.read(1))[0]
            if t == 2:  return struct.unpack("<H", f.read(2))[0]
            if t == 3:  return struct.unpack("<h", f.read(2))[0]
            if t == 4:  return struct.unpack("<I", f.read(4))[0]
            if t == 5:  return struct.unpack("<i", f.read(4))[0]
            if t == 6:  return struct.unpack("<f", f.read(4))[0]
            if t == 7:  return struct.unpack("<?", f.read(1))[0]
            if t == 8:  return rd_str()
            if t == 9:
                et, = struct.unpack("<I", f.read(4)); ln, = struct.unpack("<Q", f.read(8))
                return [rd_val(et) for _ in range(ln)]
            if t == 10: return struct.unpack("<Q", f.read(8))[0]
            if t == 11: return struct.unpack("<q", f.read(8))[0]
            if t == 12: return struct.unpack("<d", f.read(8))[0]
            raise ValueError(t)
        name = ""
        for _ in range(n_kv):
            key = rd_str(); t, = struct.unpack("<I", f.read(4)); val = rd_val(t)
            if key.endswith(".pooling_type"):
                print("e' un modello di embedding (pooling_type presente), non puo' servire la chat")
                raise SystemExit
            if key == "general.name":
                name = str(val)
        if "embedding" in name.lower():
            print("il nome del modello indica un embedding model, non puo' servire la chat")
except SystemExit:
    raise
except Exception:
    pass  # parsing fallito: non blocchiamo, lasciamo decidere a llama-server
PY
}

if [[ "$BACKEND" == "mlx-lm" ]]; then
  BIG_MLX_ISSUE="$(mlx_dir_error "${BIG_MLX:-}")"
  if [[ -n "$BIG_MLX_ISSUE" ]]; then
    echo "[ccllrun] cartella MLX big non valida: $BIG_MLX_ISSUE (${BIG_MLX:-vuota})" >&2
    exit 1
  fi
elif [[ "$BACKEND" != "llama.cpp" ]]; then
  echo "[ccllrun] backend non valido: $BACKEND (usa llama.cpp oppure mlx-lm)" >&2
  exit 2
fi

configure_upstreams
if [[ "$SERVERS_ONLY" == "1" ]]; then
  if verify_stack_ready; then
    echo "[ccllrun] stack gia' attivo e coerente."
  elif stack_has_residue; then
    echo "[ccllrun] stack parziale/incoerente: pulizia e riavvio completo..."
    cleanup_stack
  fi
fi

if [[ "$BACKEND" == "mlx-lm" ]]; then
  # ---------- big MLX ----------
  if [[ "$(openai_health "$BIG_PORT")" != "200" ]]; then
    echo "[ccllrun] avvio $MODEL_BIG MLX su :$BIG_PORT..."
    nohup "$MLX_BIN" --model "$BIG_MLX" --host 127.0.0.1 --port "$BIG_PORT" \
      >> "$CC_DIR/llama-big.log" 2>&1 &
    echo $! > "$CC_DIR/llama-big.pid"
    if ! wait_openai_health "$BIG_PORT"; then
      echo "[ccllrun] $MODEL_BIG MLX non pronto, vedi $CC_DIR/llama-big.log" >&2
      exit 1
    fi
  fi

  # ---------- small MLX ----------
  if [[ "$NO_SMALL" != "1" && -n "$SMALL_MLX" && "$SMALL_MLX" != "$BIG_MLX" && "$(openai_health "$SMALL_PORT")" != "200" ]]; then
    SMALL_MLX_ISSUE="$(mlx_dir_error "$SMALL_MLX")"
    if [[ -n "$SMALL_MLX_ISSUE" ]]; then
      echo "[ccllrun] cartella MLX small non valida: $SMALL_MLX_ISSUE ($SMALL_MLX)" >&2
      exit 1
    fi
    echo "[ccllrun] avvio $MODEL_SMALL MLX su :$SMALL_PORT..."
    nohup "$MLX_BIN" --model "$SMALL_MLX" --host 127.0.0.1 --port "$SMALL_PORT" \
      >> "$CC_DIR/llama-small.log" 2>&1 &
    echo $! > "$CC_DIR/llama-small.pid"
    if ! wait_openai_health "$SMALL_PORT"; then
      echo "[ccllrun] $MODEL_SMALL MLX non pronto, vedi $CC_DIR/llama-small.log" >&2
      exit 1
    fi
  fi
else
  # ---------- mmproj auto-detection ----------
  if [[ -z "$MMPROJ" ]]; then
    for cand in "$(dirname "$BIG_GGUF")"/mmproj-*.gguf; do
      [[ -f "$cand" ]] && MMPROJ="$cand" && break
    done
  fi
  MMPROJ_FLAGS=()
  [[ -n "$MMPROJ" && "$MMPROJ" != "off" && -f "$MMPROJ" ]] && MMPROJ_FLAGS=(--mmproj "$MMPROJ")

  # ---------- big llama.cpp ----------
  if [[ "$(health "$BIG_PORT")" != "200" ]]; then
    if [[ ! -f "$BIG_GGUF" ]]; then
      echo "[ccllrun] GGUF non trovato: $BIG_GGUF" >&2
      exit 1
    fi
    BIG_EMB="$(gguf_is_embedding "$BIG_GGUF")"
    if [[ -n "$BIG_EMB" ]]; then
      echo "[ccllrun] big_gguf $BIG_EMB: $BIG_GGUF" >&2
      echo "[ccllrun] usa un modello generativo per big_gguf (l'embedding va in embed_gguf)." >&2
      exit 1
    fi
    MTP_FLAGS=()
    case "$(echo "$BIG_GGUF" | tr '[:lower:]' '[:upper:]')" in
      *MTP*) MTP_FLAGS=(--spec-type draft-mtp --spec-draft-n-max 2) ;;
    esac
    echo "[ccllrun] avvio $MODEL_BIG su :$BIG_PORT (ctx=$CTX_BIG kv=$KV_TYPE mmproj=${MMPROJ:-no})..."
    # shellcheck disable=SC2086
    nohup "$LLAMA_BIN" --model "$BIG_GGUF" --alias "$MODEL_BIG" \
      --temp 0.6 --top-p 0.95 --top-k 20 --min-p 0 \
      "${MTP_FLAGS[@]}" ${MMPROJ_FLAGS[@]+"${MMPROJ_FLAGS[@]}"} \
      --ctx-size "$CTX_BIG" -b "$BATCH" -ub "${UBATCH:-$BATCH}" -fa on -ngl "$NGL" \
      --cache-type-k "$KV_TYPE" --cache-type-v "$KV_TYPE" \
      --cache-reuse "$CACHE_REUSE" --port "$BIG_PORT" --parallel "$PARALLEL" \
      --reasoning-budget "$REASONING_BUDGET" --presence-penalty "$PRESENCE_PENALTY" \
      $EXTRA_BIG_FLAGS \
      >> "$CC_DIR/llama-big.log" 2>&1 &
    echo $! > "$CC_DIR/llama-big.pid"
    if ! wait_health "$BIG_PORT"; then
      echo "[ccllrun] $MODEL_BIG non pronto, vedi $CC_DIR/llama-big.log" >&2
      exit 1
    fi
  fi

  # ---------- small llama.cpp ----------
  if [[ "$NO_SMALL" != "1" && -n "$SMALL_GGUF" && "$SMALL_GGUF" != "$BIG_GGUF" && "$(health "$SMALL_PORT")" != "200" ]]; then
    if [[ -f "$SMALL_GGUF" ]]; then
      SMALL_EMB="$(gguf_is_embedding "$SMALL_GGUF")"
      if [[ -n "$SMALL_EMB" ]]; then
        echo "[ccllrun] small_gguf $SMALL_EMB: $SMALL_GGUF" >&2
        echo "[ccllrun] usa un modello generativo per small_gguf (l'embedding va in embed_gguf)." >&2
        exit 1
      fi
    fi
    SMALL_BATCH="${BATCH_SMALL:-$BATCH}"
    SMALL_PARALLEL="${PARALLEL_SMALL:-$PARALLEL}"
    # The small model does not inherit the big UBATCH because llama.cpp requires
    # -ub <= -b. Without UBATCH_SMALL, use the small batch size.
    SMALL_UBATCH="${UBATCH_SMALL:-$SMALL_BATCH}"
    SMALL_CACHE_REUSE="${CACHE_REUSE_SMALL:-$CACHE_REUSE}"
    echo "[ccllrun] avvio $MODEL_SMALL su :$SMALL_PORT (ctx=$CTX_SMALL batch=$SMALL_BATCH ubatch=$SMALL_UBATCH parallel=$SMALL_PARALLEL)..."
    nohup "$LLAMA_BIN" --model "$SMALL_GGUF" --alias "$MODEL_SMALL" \
      --ctx-size "$CTX_SMALL" -b "$SMALL_BATCH" -ub "$SMALL_UBATCH" -fa on -ngl "$NGL" \
      --cache-reuse "$SMALL_CACHE_REUSE" --port "$SMALL_PORT" --parallel "$SMALL_PARALLEL" \
      >> "$CC_DIR/llama-small.log" 2>&1 &
    echo $! > "$CC_DIR/llama-small.pid"
    if ! wait_health "$SMALL_PORT"; then
      echo "[ccllrun] $MODEL_SMALL non pronto, vedi $CC_DIR/llama-small.log" >&2
      exit 1
    fi
  fi

  # ---------- optional embedding server ----------
  if [[ -n "$EMBED_GGUF" && "$(health "$EMBED_PORT")" != "200" ]]; then
    if [[ ! -f "$EMBED_GGUF" ]]; then
      echo "[ccllrun] embed_gguf non trovato: $EMBED_GGUF" >&2
      exit 1
    fi
    # This slot is intended for embedding models; warn when the GGUF looks generative.
    [[ -z "$(gguf_is_embedding "$EMBED_GGUF")" ]] && \
      echo "[ccllrun] nota: embed_gguf non sembra un modello di embedding, /v1/embeddings potrebbe non funzionare" >&2
    # Embedding requests process each input in one physical batch. A low default
    # batch can reject long chunks with "input too large", so expose a larger knob.
    echo "[ccllrun] avvio $MODEL_EMBED su :$EMBED_PORT (embedding, batch=$EMBED_BATCH)..."
    nohup "$LLAMA_BIN" --model "$EMBED_GGUF" --alias "$MODEL_EMBED" \
      --embedding --pooling mean -ngl "$NGL" --port "$EMBED_PORT" \
      -b "$EMBED_BATCH" -ub "$EMBED_BATCH" --ctx-size "$EMBED_BATCH" \
      >> "$CC_DIR/llama-embed.log" 2>&1 &
    echo $! > "$CC_DIR/llama-embed.pid"
    if ! wait_health "$EMBED_PORT"; then
      echo "[ccllrun] $MODEL_EMBED non pronto, vedi $CC_DIR/llama-embed.log" >&2
      exit 1
    fi
  fi
fi

# ---------- proxy + claude ----------
# Bootstrap ~/.ccllrun/proxy.py from the script directory so a symlinked ccllrun
# installation can keep the runtime proxy in sync with the checkout.
mkdir -p "$CC_DIR"
SELF="$0"; [[ -L "$SELF" ]] && SELF="$(readlink "$SELF")"
SELF_DIR="$(cd "$(dirname "$SELF")" && pwd)"
if [[ -f "$SELF_DIR/proxy.py" ]] && ! cmp -s "$SELF_DIR/proxy.py" "$CC_DIR/proxy.py"; then
  cp "$SELF_DIR/proxy.py" "$CC_DIR/proxy.py"
  echo "[ccllrun] proxy.py installato/aggiornato in $CC_DIR"
fi
if [[ ! -f "$CC_DIR/proxy.py" ]]; then
  echo "[ccllrun] manca $CC_DIR/proxy.py (e non trovo proxy.py accanto allo script)" >&2
  exit 1
fi
if [[ ! -x "$VENV/bin/python" ]]; then
  echo "[ccllrun] primo avvio: creo il venv..."
  python3 -m venv "$VENV" || exit 1
  "$VENV/bin/pip" install -q --upgrade pip aiohttp pymupdf || exit 1
fi

SMALL_UPSTREAM=""
if [[ "$BACKEND" == "mlx-lm" ]]; then
  [[ "$NO_SMALL" != "1" && -n "$SMALL_MLX" && "$SMALL_MLX" != "$BIG_MLX" ]] && SMALL_UPSTREAM="http://127.0.0.1:$SMALL_PORT"
else
  [[ "$NO_SMALL" != "1" && -n "$SMALL_GGUF" && "$SMALL_GGUF" != "$BIG_GGUF" ]] && SMALL_UPSTREAM="http://127.0.0.1:$SMALL_PORT"
fi

# The embedding slot is llama.cpp-only here; mlx_lm.server is not wired for it.
EMBED_UPSTREAM=""
[[ "$BACKEND" != "mlx-lm" && -n "$EMBED_GGUF" ]] && EMBED_UPSTREAM="http://127.0.0.1:$EMBED_PORT"

if [[ "$(health "$BIG_PORT")" != "200" ]]; then
  echo "[ccllrun] $MODEL_BIG non pronto o non piu' attivo, vedi $CC_DIR/llama-big.log" >&2
  exit 1
fi
if [[ -n "$SMALL_UPSTREAM" && "$(health "$SMALL_PORT")" != "200" ]]; then
  echo "[ccllrun] $MODEL_SMALL non pronto o non piu' attivo, vedi $CC_DIR/llama-small.log" >&2
  exit 1
fi
if [[ -n "$EMBED_UPSTREAM" && "$(health "$EMBED_PORT")" != "200" ]]; then
  echo "[ccllrun] $MODEL_EMBED non pronto o non piu' attivo, vedi $CC_DIR/llama-embed.log" >&2
  exit 1
fi

# Do not start a second proxy on the same port; it would die immediately and
# leave a stale pidfile.
PROXY_PID=""
if [[ "$(proxy_health)" != "200" ]]; then
  CCRUN_UPSTREAM="http://127.0.0.1:$BIG_PORT" \
  CCRUN_UPSTREAM_SMALL="$SMALL_UPSTREAM" \
  CCRUN_UPSTREAM_EMBED="$EMBED_UPSTREAM" \
  CCRUN_UPSTREAM_API="$([[ "$BACKEND" == "mlx-lm" ]] && echo openai || echo anthropic)" \
  CCRUN_SMALL_NAME="$MODEL_SMALL" \
  CCRUN_PROXY_PORT="$PORT" \
  CCRUN_PDF_MODE="$PDF_MODE" \
  "$VENV/bin/python" "$CC_DIR/proxy.py" >> "$CC_DIR/proxy.log" 2>&1 &
  PROXY_PID=$!
  trap 'kill $PROXY_PID 2>/dev/null' INT TERM
  for _ in $(seq 1 50); do
    [[ "$(proxy_health)" == "200" ]] && break
    sleep 0.1
  done
  if [[ "$(proxy_health)" != "200" ]]; then
    echo "[ccllrun] proxy non pronto su :$PORT, vedi $CC_DIR/proxy.log" >&2
    exit 1
  fi
fi

if [[ "$SERVERS_ONLY" == "1" ]]; then
  sleep 1
  if ! verify_stack_ready; then
    echo "[ccllrun] stack non stabile dopo l'avvio, controlla i log in $CC_DIR" >&2
    exit 1
  fi
  if [[ -n "$PROXY_PID" ]]; then
    echo "$PROXY_PID" > "$CC_DIR/proxy.pid"
  else  # proxy preesistente riusato: registra il pid vero
    /usr/sbin/lsof -ti "tcp:$PORT" -sTCP:LISTEN 2>/dev/null | head -1 > "$CC_DIR/proxy.pid"
  fi
  trap - INT TERM
  if [[ -n "$EMBED_UPSTREAM" ]]; then
    echo "[ccllrun] server attivi: big :$BIG_PORT, small :$SMALL_PORT, embed :$EMBED_PORT, proxy :$PORT (ferma con: ccllrun stop)"
  else
    echo "[ccllrun] server attivi: big :$BIG_PORT, small :$SMALL_PORT, proxy :$PORT (ferma con: ccllrun stop)"
  fi
  exit 0
fi

# Force tool search from cc_tool_search so ccllrun wins over a global
# ENABLE_TOOL_SEARCH value in Claude Code settings. "1" enables it; empty
# leaves it off.
if [[ "$CC_TOOL_SEARCH" == "1" || "$CC_TOOL_SEARCH" == "true" ]]; then
  TOOL_SEARCH_ENV=1
else
  TOOL_SEARCH_ENV=""
fi

build_kb_flags() {
  # Add the configured knowledge-base directory to Claude Code's readable roots.
  KB_FLAGS=()
  [[ -n "$KB_DIR" ]] || return 0
  KB_PATH="${KB_DIR/#\~/$HOME}"
  if [[ -e "$KB_PATH" ]]; then
    KB_FLAGS=(--add-dir "$KB_PATH")
  else
    echo "[ccllrun] nota: kb_dir non trovato, ignorato: $KB_PATH" >&2
  fi
}

build_kb_flags

ANTHROPIC_BASE_URL="http://127.0.0.1:$PORT" \
ANTHROPIC_AUTH_TOKEN="${ANTHROPIC_AUTH_TOKEN:-sk-local}" \
ANTHROPIC_MODEL="$MODEL_BIG" \
ANTHROPIC_SMALL_FAST_MODEL="$MODEL_SMALL" \
CLAUDE_CODE_AUTO_COMPACT_WINDOW="${CLAUDE_CODE_AUTO_COMPACT_WINDOW:-$CC_AUTO_COMPACT_WINDOW}" \
CLAUDE_CODE_MAX_OUTPUT_TOKENS="${CLAUDE_CODE_MAX_OUTPUT_TOKENS:-$CC_MAX_OUTPUT_TOKENS}" \
ENABLE_TOOL_SEARCH="$TOOL_SEARCH_ENV" \
claude "${KB_FLAGS[@]}" "${CLAUDE_ARGS[@]}"
code=$?
[[ -n "$PROXY_PID" ]] && kill "$PROXY_PID" 2>/dev/null
trap - INT TERM
exit $code
